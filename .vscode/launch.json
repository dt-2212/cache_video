  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Cache Video (Debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug"
    },
    {
        "name": "Flutter Cache Video (Profile)",
        "request": "launch",
        "type": "dart",
        "program": "lib/main.dart",
        "flutterMode": "profile"
    },
    {
        "name": "Flutter Cache Video (Release)",
        "request": "launch",
        "type": "dart",
        "program": "lib/main.dart",
        "flutterMode": "release"
    },
    {
        "name": "Flutter Cache Video (Debug - All Devices)",
        "request": "launch",
        "type": "dart",
        "program": "lib/main.dart",
        "flutterMode": "debug",
        "additionalArgs": [
            "-d",
            "all"
        ]
    }
  ],
  "compounds": []
}
